# Copy this file to .env on the server. Current phases do not require secrets.
VMP_CONFIG_PATH=configs/default.yaml
VMP_WORKSPACE_DIR=memory_workspace
VMP_OUTPUT_DIR=outputs
VMP_LOG_LEVEL=INFO
VMP_RANDOM_SEED=42
VMP_EMBEDDING_MODEL=BAAI/bge-m3
VMP_EMBEDDING_DEVICE=auto
VMP_EMBEDDING_DIMENSION=1024
VMP_OFFICIAL_MEMORY_INFER=true
VMP_OFFICIAL_LLM_MAX_TOKENS=512
VMP_OFFICIAL_LLM_TEMPERATURE=0.0

# Optional cache locations for the embedding phase. Leave empty to use the
# server defaults; never commit machine-specific absolute paths.
HF_HOME=
SENTENCE_TRANSFORMERS_HOME=

# Optional providers reserved for later phases.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Optional vLLM OpenAI-compatible server settings.
VMP_LLM_BASE_URL=http://127.0.0.1:8000/v1
VMP_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
VMP_LLM_API_KEY=
VMP_LLM_TIMEOUT_SECONDS=120
VMP_VLLM_HOST=0.0.0.0
VMP_VLLM_PORT=8000
VMP_VLLM_DTYPE=auto
VMP_VLLM_GPU_MEMORY_UTILIZATION=0.90
VMP_VLLM_MAX_MODEL_LEN=
VMP_VLLM_TENSOR_PARALLEL_SIZE=
VMP_VLLM_ENABLE_TOOL_CALLING=1
VMP_VLLM_TOOL_CALL_PARSER=hermes
VMP_VLLM_EXTRA_ARGS=

# Graphiti requires its own disposable Neo4j instance. The benchmark clears all
# nodes before every question; never point these values at an existing database.
VMP_GRAPHITI_NEO4J_URI=bolt://127.0.0.1:7687
VMP_GRAPHITI_NEO4J_USER=neo4j
VMP_GRAPHITI_NEO4J_PASSWORD=
VMP_GRAPHITI_NEO4J_CONTAINER=vmp-graphiti-neo4j
VMP_GRAPHITI_ALLOW_DESTRUCTIVE_RESET=false

# Self-hosted official Letta server and shared BGE-M3 embedding endpoint.
VMP_LETTA_BASE_URL=http://127.0.0.1:8283
VMP_LETTA_API_KEY=
VMP_LETTA_SERVER_VERSION=0.16.8
VMP_LETTA_EMBEDDING_BASE_URL=http://127.0.0.1:8001/v1
VMP_LETTA_CONTEXT_WINDOW=16384
VMP_LETTA_CONTAINER=vmp-letta
VMP_LETTA_IMAGE=letta/letta:0.16.8
VMP_LETTA_VOLUME=vmp-letta-data
